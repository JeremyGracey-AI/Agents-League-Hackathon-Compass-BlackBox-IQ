<?xml version="1.0" encoding="UTF-8"?>
<!--
  Vendor Operations ontology — the Meaning lens (Fabric IQ).

  Authored in the Microsoft Fabric IQ ontology format (RDF/OWL) used by
  github.com/microsoft/Ontology-Playground ("the exact format Microsoft Fabric
  IQ expects"). This is a real ontology, not a document: it models business
  CONCEPTS and the relationships between them. The semantic core — a PaymentTerm
  whose netDays exceed the policy's standardNetDays is classified as a
  TermDeviation, which requiresApproval — is what lets an agent conclude that
  "net-60 requires human approval" as a modeled inference rather than a lookup.

  Orthogonal to the vault: this models MEANING, not the governed payment policy
  (which lives in the vault as kn-payment-policy) and not the vendor master fact
  (which lives in Foundry IQ). Grounding only — never merged into governed memory.
-->
<rdf:RDF
    xml:base="http://compass-blackbox-iq.example/ontology/vendor-ops/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://compass-blackbox-iq.example/ontology/vendor-ops/">

    <owl:Ontology rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/">
        <rdfs:label>Vendor Operations</rdfs:label>
        <rdfs:comment>Accounts-payable semantics: vendors, invoices, payment terms, and the deviation-to-approval relationships that give a term business meaning.</rdfs:comment>
    </owl:Ontology>

    <!-- ======== Classes ======== -->

    <owl:Class rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/Vendor">
        <rdfs:label>Vendor</rdfs:label>
        <rdfs:comment>A supplier the company transacts with</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/Invoice">
        <rdfs:label>Invoice</rdfs:label>
        <rdfs:comment>A bill a vendor issues for payment</rdfs:comment>
        <ont:icon>🧾</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentTerm">
        <rdfs:label>PaymentTerm</rdfs:label>
        <rdfs:comment>The payment timeframe agreed on an invoice, e.g. net-30 or net-60</rdfs:comment>
        <ont:icon>📅</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentPolicy">
        <rdfs:label>PaymentPolicy</rdfs:label>
        <rdfs:comment>The company standard that defines acceptable payment terms</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/TermDeviation">
        <rdfs:label>TermDeviation</rdfs:label>
        <rdfs:comment>A payment term whose netDays exceed the policy standardNetDays — a departure from standard that carries an approval obligation</rdfs:comment>
        <ont:icon>⚠️</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/ApprovalRequirement">
        <rdfs:label>ApprovalRequirement</rdfs:label>
        <rdfs:comment>A control requiring human authorization before a commitment is made</rdfs:comment>
        <ont:icon>🔒</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/Approver">
        <rdfs:label>Approver</rdfs:label>
        <rdfs:comment>The human authority who can authorize a term deviation</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#038387</ont:color>
    </owl:Class>

    <!-- ======== Vendor Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/vendor_vendorId">
        <rdfs:label>vendorId</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Vendor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/vendor_legalName">
        <rdfs:label>legalName</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Vendor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/vendor_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Vendor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:enumValues>active,inactive,pending</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Invoice Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/invoice_invoiceId">
        <rdfs:label>invoiceId</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Invoice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/invoice_amount">
        <rdfs:label>amount</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Invoice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/invoice_issuedDate">
        <rdfs:label>issuedDate</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Invoice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== PaymentTerm Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/paymentterm_termCode">
        <rdfs:label>termCode</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentTerm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/paymentterm_netDays">
        <rdfs:label>netDays</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentTerm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>days</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/paymentterm_isStandard">
        <rdfs:label>isStandard</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentTerm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== PaymentPolicy Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/paymentpolicy_name">
        <rdfs:label>policyName</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/paymentpolicy_standardNetDays">
        <rdfs:label>standardNetDays</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentPolicy"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>days</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== ApprovalRequirement Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/approvalrequirement_control">
        <rdfs:label>control</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/ApprovalRequirement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Approver Properties ======== -->

    <owl:DatatypeProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/approver_role">
        <rdfs:label>role</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Approver"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ======== Relationships (the Meaning) ======== -->

    <owl:ObjectProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/vendor_issues_invoice">
        <rdfs:label>issues</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Vendor"/>
        <rdfs:range rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Invoice"/>
        <rdfs:comment>A vendor issues one or more invoices</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>vendor</ont:fromEntityId>
        <ont:toEntityId>invoice</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/invoice_carries_paymentterm">
        <rdfs:label>carries</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Invoice"/>
        <rdfs:range rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentTerm"/>
        <rdfs:comment>An invoice carries exactly one payment term</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>invoice</ont:fromEntityId>
        <ont:toEntityId>paymentterm</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/paymentterm_governedBy_paymentpolicy">
        <rdfs:label>governedBy</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentTerm"/>
        <rdfs:range rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentPolicy"/>
        <rdfs:comment>Every payment term is governed by the company payment policy, which sets standardNetDays</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>paymentterm</ont:fromEntityId>
        <ont:toEntityId>paymentpolicy</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/paymentterm_classifiedAs_termdeviation">
        <rdfs:label>classifiedAs</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/PaymentTerm"/>
        <rdfs:range rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/TermDeviation"/>
        <rdfs:comment>A payment term whose netDays exceed the policy standardNetDays is classified as a TermDeviation</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>paymentterm</ont:fromEntityId>
        <ont:toEntityId>termdeviation</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/termdeviation_requiresApproval_approvalrequirement">
        <rdfs:label>requiresApproval</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/TermDeviation"/>
        <rdfs:range rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/ApprovalRequirement"/>
        <rdfs:comment>A term deviation requires human approval before the invoice can be committed</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>termdeviation</ont:fromEntityId>
        <ont:toEntityId>approvalrequirement</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://compass-blackbox-iq.example/ontology/vendor-ops/approvalrequirement_routesTo_approver">
        <rdfs:label>routesTo</rdfs:label>
        <rdfs:domain rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/ApprovalRequirement"/>
        <rdfs:range rdf:resource="http://compass-blackbox-iq.example/ontology/vendor-ops/Approver"/>
        <rdfs:comment>An approval requirement routes to a human approver</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>approvalrequirement</ont:fromEntityId>
        <ont:toEntityId>approver</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
